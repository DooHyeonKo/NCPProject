# 3-Tier deployment environment
# Copy this file to .env on the server and replace every placeholder.

# Public endpoints used by the browser.
PUBLIC_FRONTEND_ORIGIN=http://YOUR_SERVER_PUBLIC_IP:3000
NEXT_PUBLIC_API_BASE_URL=http://YOUR_SERVER_PUBLIC_IP:8000/api/v1
NEXT_PUBLIC_BACKEND_HEALTH_URL=http://YOUR_SERVER_PUBLIC_IP:8000/health

# Backend CORS origin. Usually identical to PUBLIC_FRONTEND_ORIGIN.
FRONTEND_ORIGIN=http://YOUR_SERVER_PUBLIC_IP:3000

# Data tier: NCP Cloud DB for PostgreSQL or another external PostgreSQL.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@DB_HOST:5432/DB_NAME

# Security.
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# CLOVA Studio.
CLOVA_STUDIO_API_KEY=replace-with-clova-api-key
CLOVA_STUDIO_BASE_URL=https://clovastudio.stream.ntruss.com/v1/openai
CLOVA_CHAT_MODEL=HCX-005
CLOVA_EMBEDDING_MODEL=bge-m3

# Upload limits.
MAX_UPLOAD_SIZE_MB=40

# Data tier: NCP Object Storage.
NCP_OBJECT_STORAGE_ENDPOINT=https://kr.object.ncloudstorage.com
NCP_OBJECT_STORAGE_REGION=kr-standard
NCP_OBJECT_STORAGE_ACCESS_KEY=replace-with-ncp-access-key
NCP_OBJECT_STORAGE_SECRET_KEY=replace-with-ncp-secret-key
NCP_OBJECT_STORAGE_BUCKET=atoz-upload-bucket
